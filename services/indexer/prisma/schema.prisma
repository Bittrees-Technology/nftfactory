generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Collection {
  id                 String   @id @default(cuid())
  chainId            Int
  contractAddress    String   @unique
  ownerAddress       String
  ensSubname         String?
  standard           String
  isFactoryCreated   Boolean  @default(true)
  isUpgradeable      Boolean  @default(true)
  finalizedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tokens             Token[]
}

model Token {
  id                 String   @id @default(cuid())
  collectionId       String
  tokenId            String
  creatorAddress     String
  ownerAddress       String
  mintTxHash         String?
  draftName          String?
  draftDescription   String?
  mintedAmountRaw    String?
  metadataCid        String
  mediaCid           String?
  immutable          Boolean  @default(true)
  mintedAt           DateTime @default(now())
  tags               TokenTag[]
  holdings           TokenHolding[]
  listings           Listing[]
  offers             Offer[]
  reports            Report[]
  moderationActions  ModerationAction[]

  collection         Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, tokenId])
}

model Listing {
  id                 String   @id @default(cuid())
  listingId          String   @unique
  chainId            Int
  marketplaceVersion String   @default("v1")
  collectionAddress  String
  tokenId            String
  sellerAddress      String
  amountRaw          String   @default("1")
  standard           String   @default("UNKNOWN")
  paymentToken       String
  priceRaw           String
  expiresAtRaw       String   @default("0")
  active             Boolean  @default(true)
  lastSyncedAt       DateTime @default(now())
  cancelledAt        DateTime?
  soldAt             DateTime?
  buyerAddress       String?
  txHash             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tokenRefId         String?

  token              Token?   @relation(fields: [tokenRefId], references: [id], onDelete: SetNull)
}

model Offer {
  id                   String   @id @default(cuid())
  offerId              String   @unique
  chainId              Int
  marketplaceVersion   String   @default("v2")
  collectionAddress    String
  tokenId              String
  buyerAddress         String
  paymentToken         String
  quantityRaw          String
  priceRaw             String
  expiresAtRaw         String
  status               String
  active               Boolean  @default(true)
  acceptedByAddress    String?
  acceptedSellerAddress String?
  acceptedTxHash       String?
  cancelledTxHash      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  lastSyncedAt         DateTime @default(now())
  tokenRefId           String?

  token                Token?   @relation(fields: [tokenRefId], references: [id], onDelete: SetNull)

  @@index([buyerAddress, active, updatedAt])
  @@index([collectionAddress, tokenId, active, updatedAt])
  @@index([status, updatedAt])
}

model TokenHolding {
  id                 String   @id @default(cuid())
  tokenId            String
  ownerAddress       String
  quantityRaw        String   @default("0")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  token              Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([tokenId, ownerAddress])
  @@index([ownerAddress, updatedAt])
  @@index([tokenId, updatedAt])
}

model Tag {
  id                 String   @id @default(cuid())
  slug               String   @unique
  label              String
  isSystem           Boolean  @default(false)
  usageCount         Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tokenLinks         TokenTag[]
}

model TokenTag {
  id                 String   @id @default(cuid())
  tokenId            String
  tagId              String
  addedByAddress     String
  createdAt          DateTime @default(now())

  token              Token @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  tag                Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tokenId, tagId, addedByAddress])
}

model Report {
  id                 String   @id @default(cuid())
  tokenId            String
  reporterAddress    String
  reason             String
  evidence           String?
  status             String   @default("open")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  token              Token @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId, status])
}

model ModerationAction {
  id                 String   @id @default(cuid())
  tokenId            String
  reportId           String?
  action             String
  actor              String
  notes              String?
  createdAt          DateTime @default(now())

  token              Token @relation(fields: [tokenId], references: [id], onDelete: Cascade)
}
