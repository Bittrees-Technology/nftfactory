# Run one indexer instance per chain. Example:
# CHAIN_ID=1 INDEXER_PORT=8787 RPC_URL=... pnpm dev
# CHAIN_ID=10 INDEXER_PORT=8788 RPC_URL=... pnpm dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nftfactory
RPC_URL=
CHAIN_ID=11155111
INDEXER_PORT=8787
INDEXER_ADMIN_TOKEN=
INDEXER_ADMIN_ALLOWLIST=
MODERATOR_REGISTRY_ADDRESS=
# Set true only when running behind a trusted proxy/load balancer that sets X-Forwarded-For.
TRUST_PROXY=false
