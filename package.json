{
  "name": "nftfactory",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "dev:indexer": "npm --workspace services/indexer run dev",
    "security:setup": "bash scripts/setup-githooks.sh",
    "security:scan-staged": "bash scripts/check-secrets.sh"
  }
}
