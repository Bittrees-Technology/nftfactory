{
  "name": "nftfactory",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:web:clean": "npm --workspace apps/web run dev:clean",
    "build:web": "npm --workspace apps/web run build",
    "build:web:clean": "npm --workspace apps/web run build:clean",
    "lint:web": "npm --workspace apps/web run lint",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "test:web": "npm --workspace apps/web run test",
    "typecheck:indexer": "npm --workspace services/indexer run typecheck",
    "test:indexer": "npm --workspace services/indexer run test",
    "dev:indexer": "npm --workspace services/indexer run dev",
    "test:contracts": "npm --workspace packages/contracts run test",
    "docs:contracts-deps": "bash scripts/generate-contract-dependency-tree.sh",
    "check:ensv2": "node scripts/check-ensv2-readiness.mjs",
    "check:ipfs": "bash scripts/ipfs-readiness.sh",
    "check:web-env": "node scripts/check-web-build-env.mjs",
    "check:deployments": "node scripts/check-deployment-addresses.mjs",
    "print:deployment-env": "node scripts/print-deployment-env.mjs",
    "validate:release": "npm run typecheck:web && npm run test:web && npm run build:web:clean && npm run typecheck:indexer && npm run test:indexer && npm run test:contracts",
    "check:release": "bash scripts/release-readiness.sh",
    "typecheck:all": "npm run typecheck:web && npm run typecheck:indexer",
    "test:all": "npm run test:web && npm run test:indexer && npm run test:contracts",
    "check:all": "npm run typecheck:all && npm run test:all",
    "ipfs:publish": "node scripts/publish-artifact.mjs",
    "ipfs:publish:metadata": "node scripts/publish-metadata-json.mjs"
  }
}
